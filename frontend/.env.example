# Google Sheets CSV URL (required for dynamic categories)
# 1. Open your Google Sheet
# 2. File > Share > Publish to web
# 3. Select the sheet tab, format: CSV or TSV
# 4. Paste the URL here
VITE_SHEET_CSV_URL=

# WebSocket URL (set this to your Render backend URL)
# Local: ws://localhost:8080/ws
# Production: wss://your-backend.onrender.com/ws
VITE_WS_URL=
